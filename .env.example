# Copy to `.env` and fill in your key (or export these in your shell).
# The code reads OPENAI_API_KEY (falls back to OPENAI_APIKEY).
OPENAI_API_KEY=sk-...

# ---- Optional runtime toggles (defaults shown) ----
USE_RAG=1            # 1: query ChromaDB for evidence, 0: skip RAG
USE_TOPK=1           # 1: extract Top-K terms and inject into next step's RAG query
USE_VISION=1         # 1: analyze MMD figure PNGs with GPT vision
TOPK_K=5             # number of Top-K terms/phrases to extract
LOG_TAIL=20000       # chars of log tail fed to the LLM
RAGAS_EMBED_MODEL=text-embedding-3-small
