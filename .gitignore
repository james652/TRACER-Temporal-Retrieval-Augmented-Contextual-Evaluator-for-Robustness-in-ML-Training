# ===== Runtime outputs (generated by the agent) =====
# LOG_DIR = .../logs  → step logs, memory, top-k, vision, reports
logs/*
!logs/.gitkeep

# Ablation result dirs referenced by ablation_extract.py / ablation_compare.py
A_result*/

# ===== RAG artifacts (regenerate with rag/ingest.py) =====
chroma_db/
embed/
*.sqlite3

# ===== Source papers (download separately; see README) =====
paper/
*.pdf

# ===== Datasets & large checkpoints (NOT for git) =====
data/
*.pkl
*.pth
*.tar.gz
*.ckpt

# ===== Secrets =====
.env
.env.local

# ===== Python =====
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/

